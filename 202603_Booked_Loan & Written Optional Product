CREATE OR REPLACE TEMPORARY TABLE bdm.temp_loan_base_jy AS

SELECT 
    b.uai_id,
    b.acap_refr_id,
    b.tran_date,
    b.tran_end_dt AS month,
    b.core_v_capp AS core_capp_filter,
    
    case when b.cust_type in ('NC','FC') then 'NCFC' else 'PC' end as cust,
    b.cust_type as cust2,
    
    case when b.channel = 'Internet: Affiliate' then 'Affiliate'
         when b.channel like 'I%' then 'Digital Direct'
         else 'Branch' end as channel,
         
    case when e.channel in ('Internet: Search','Internet: Email') then e.channel
         when trim(f.channel_int_detail) in ('Internet: SEO') then 'Internet: SEO'
         when e.channel is null then 'n/a'
         when e.channel in ('Internet: Affiliate') then 'n/a'
         when e.channel in ('Internet: Affinity','Internet: Decline Referral','Internet: Direct Auto','Internet: Lead Referral','Internet: Merchant','Internet: Other','Internet: Organic','Internet: Display','Internet: Social') then 'Other Internet'
         else 'n/a' end as digital_direct_channel,
         
    case when b.iaps_src_cd in ('90070') then 'CK API'
         when b.iaps_src_cd in ('31411','31427','31438') then 'CK LBOX'
         when b.iaps_src_cd in ('30637') then 'CK LINK'
         when b.iaps_src_cd in ('30596','31305','31403','31409','90024') then 'Lend Tree'
         when trim(e.descr) in ('Quin Street','Even Financial') then trim(e.descr)
         when b.channel ='Internet: Affiliate' then 'Other Affiliates'
         else 'n/a' end as affiliate_grp,
         
    case when b.rsk_lvl in ('S','P','A','B','C') then b.rsk_lvl else 'D-' end as risk,
    
    case when b.offer_type in ('sec only','review') then 'sec only'
         when b.offer_type in ('Null','decline') then 'decline'
         else b.offer_type end as offer_type,
         
    d.sdl,
    b.smd_nm,
    b.BRANCH_NM,
    b.OWN_SCORE_BRNCH,
    
    case when b.branch_group = 'CFG' and b.branch_nm not like '%CENTRALIZED%' then b.branch_st else b.p_adr_st end as state,
    'Actuals' as segment,
    
    case when b.branch_group = 'CFG' and b.branch_nm not like '%CENTRALIZED%' and b.branch_st = 'IL' then 'include'
         when b.fdc_elig = 'Y' and b.fdc_off_ramp is null then 'include'
         when b.branch_group <> 'CFG' then 'exclude'
         when b.branch_nm like '%CENTRALIZED%' then 'exclude'
         else 'include' end as cpl_filter,
         
    b.reactive_flag,
    case when extract(dayofweek from b.tran_date) = 0 and b.tran_date < current_date - 2 then 1
         when extract(dayofweek from b.tran_date) <> 0 and b.tran_date <= current_date - 2 then 1 
         else 0 end as Net_CPL_Loan_Flag

FROM bdm.app_loan_production b
LEFT JOIN bdm.initiatives d 
    ON b.acap_refr_id = d.acap_refr_id and b.acap_refr_id > 0
LEFT JOIN bdm.internet_source_codes e 
    ON trim(b.iaps_src_cd) = trim(e.source_code) and b.iaps_src_cd::numeric > 0
LEFT JOIN BDM.REPORTING_STANDARDIZED_TOUCH_POINTS f 
    ON b.appl_key = f.appl_key and b.appl_key > 0

WHERE b.tran_date >= '2019-01-01'
  AND (b.core_v_capp = 'Core' OR b.core_v_capp IS NULL)
  -- ADDED HARD FILTER: Permanently excluding 'decline' and 'Null' offers
  AND b.offer_type NOT IN ('decline', 'Null');

  /** QUICK SANITY CHECK ON TOTAL BOOKED LOANS**/

  SELECT YEAR(MONTH), SUM(Net_CPL_Loan_Flag) FROM BDM.TEMP_LOAN_BASE_JY GROUP BY 1 ORDER BY 1 ASC; 
  
  /** QUICK SANITY CHECK ON DIFFERENT TYPES OF OP**/
  
  SELECT 
    year(a.coverage_effective_dt) as coverage_year,
    a.coverage_abbreviation_cd AS Product_Code,
    
    -- Checks if Brendan's script includes or ignores this product
    CASE 
        WHEN a.coverage_abbreviation_cd IN ('SCL','SCA','IUI','GAP','DIP','MLP','ATL','HA','SSG') THEN 'Included in CPL'
        ELSE 'Excluded from CPL' --- AUT is excluded because it is not optional 
    END AS CPL_Inclusion_Status,

    COUNT(a.uai_id) AS Total_Rows,
    
    -- Adding this just to see how many of these rows are actual sales vs. zero-dollar adjustments
    SUM(CASE WHEN a.SALE_CT = 1 THEN 1 ELSE 0 END) AS Valid_Sales_Count

FROM core.optional_product_sale a
INNER JOIN bdm.temp_loan_base_jy b 
    ON a.uai_id = b.uai_id

WHERE a.uai_id IS NOT NULL 
  AND (a.coverage_effective_dt >= '2019-01-01' OR a.cancel_effective_dt >= '2019-01-01')

GROUP BY 1, 2,3
ORDER BY Total_Rows DESC;

CREATE OR REPLACE TEMPORARY TABLE bdm.temp_ops_product_jy AS

SELECT 
    a.*,
    
    -- Inheriting dimensions from the loan base
    b.cust,
    b.cust2,
    b.channel,
    b.digital_direct_channel,
    b.affiliate_grp,
    b.risk,
    b.offer_type,
    b.sdl,
    b.smd_nm,
    b.BRANCH_NM,
    b.OWN_SCORE_BRNCH,
    b.state,
    b.segment,
    b.cpl_filter,
    b.core_capp_filter,
    b.reactive_flag,

    -- Sold Flag Logic
    case when c_sale.day_of_week = 'Sun' and a.coverage_effective_dt < current_date - 2 and a.coverage_abbreviation_cd in ('SCL','SCA','IUI','GAP','DIP','MLP','ATL','HA','SSG') then 1
         when c_sale.day_of_week <> 'Sun' and a.coverage_effective_dt <= current_date - 2 and a.coverage_abbreviation_cd in ('SCL','SCA','IUI','GAP','DIP','MLP','ATL','HA','SSG') then 1 
         else 0 end as NET_CPL_SOLD_FLAG,

    -- Cancel Flag Logic
    case when a.cancel_60day_ct = 1 and a.customer_initiated_cancel_yn = 'Y' and c_can.day_of_week = 'Sun' and a.cancel_effective_dt < current_date - 2 and a.coverage_abbreviation_cd in ('SCL','SCA','IUI','GAP','DIP','MLP','ATL','HA','SSG') then 1
         when a.cancel_60day_ct = 1 and a.customer_initiated_cancel_yn = 'Y' and c_can.day_of_week <> 'Sun' and a.cancel_effective_dt <= current_date - 2 and a.coverage_abbreviation_cd in ('SCL','SCA','IUI','GAP','DIP','MLP','ATL','HA','SSG') then 1 
         else 0 end as NET_CPL_CANCEL_FLAG

FROM core.optional_product_sale a
INNER JOIN bdm.temp_loan_base_jy b 
    ON a.uai_id = b.uai_id
LEFT JOIN bdm.business_day_calendar c_sale 
    ON a.coverage_effective_dt = c_sale.day_of_month
LEFT JOIN bdm.business_day_calendar c_can 
    ON a.cancel_effective_dt = c_can.day_of_month
    
  
  WHERE a.uai_id IS NOT NULL 
  AND a.SALE_CT = 1 -- DEDUP MULTI-ENTRIES 
  AND (a.coverage_effective_dt >= '2019-01-01' OR a.cancel_effective_dt >= '2019-01-01') --BRENDAN'S LOGIC ENDS HERE 
-- ADDED HARD FILTER: Permanently excluding 'decline' and 'Null' offers from the product universe
  AND b.offer_type NOT IN ('decline', 'Null')
-- Deduplication safety net
QUALIFY ROW_NUMBER() OVER (
    PARTITION BY a.uai_id, a.coverage_abbreviation_cd 
    ORDER BY a.coverage_effective_dt DESC
) = 1;

  /** QUICK SANITY CHECK ON LOAN, SOLD, CANCEL **/

WITH loans AS (
    SELECT 
        EXTRACT(YEAR FROM tran_date) AS Report_Year,
        cpl_filter,
        SUM(Net_CPL_Loan_Flag) AS Net_CPL_Loans
    FROM bdm.temp_loan_base_jy
    WHERE core_capp_filter = 'Core' OR core_capp_filter IS NULL
    GROUP BY 1, 2
),
sold AS (
    SELECT 
        EXTRACT(YEAR FROM coverage_effective_dt) AS Report_Year,
        cpl_filter,
        SUM(NET_CPL_SOLD_FLAG) AS Products_Sold
    FROM bdm.temp_ops_product_jy
    WHERE core_capp_filter = 'Core' OR core_capp_filter IS NULL
    GROUP BY 1, 2
),
cancels AS (
    SELECT 
        EXTRACT(YEAR FROM cancel_effective_dt) AS Report_Year,
        cpl_filter,
        SUM(NET_CPL_CANCEL_FLAG) AS Products_Cancelled
    FROM bdm.temp_ops_product_jy
    WHERE core_capp_filter = 'Core' OR core_capp_filter IS NULL
    GROUP BY 1, 2
)

SELECT 
    COALESCE(l.Report_Year, s.Report_Year, c.Report_Year) AS Report_Year,
    COALESCE(l.cpl_filter, s.cpl_filter, c.cpl_filter) AS cpl_filter,
    COALESCE(l.Net_CPL_Loans, 0) AS Total_Core_Loans,
    COALESCE(s.Products_Sold, 0) AS Core_Products_Sold,
    COALESCE(c.Products_Cancelled, 0) AS Core_Products_Cancelled,
    ROUND((COALESCE(s.Products_Sold, 0) - COALESCE(c.Products_Cancelled, 0))::NUMERIC / NULLIF(l.Net_CPL_Loans, 0), 2) AS Net_Core_CPL
FROM loans l
FULL OUTER JOIN sold s 
    ON l.Report_Year = s.Report_Year AND l.cpl_filter = s.cpl_filter
FULL OUTER JOIN cancels c 
    ON COALESCE(l.Report_Year, s.Report_Year) = c.Report_Year 
    AND COALESCE(l.cpl_filter, s.cpl_filter) = c.cpl_filter
WHERE COALESCE(l.Report_Year, s.Report_Year, c.Report_Year) IS NOT NULL
ORDER BY 1 DESC, 2 ASC;

-- ====================================================================
-- YEARLY PRODUCT VOLUME SUMMARY (2019-2025)
-- Purpose: Pivots individual product volumes and compares against 
--          Total Core Loans and Total Core Products Sold.
-- ====================================================================

WITH loans AS (
    SELECT 
        EXTRACT(YEAR FROM tran_date) AS SALES_YEAR,
        SUM(Net_CPL_Loan_Flag) AS TOTAL_BOOKED_LOANS
    FROM bdm.temp_loan_base_jy
    WHERE core_capp_filter = 'Core' OR core_capp_filter IS NULL
    GROUP BY 1
),
products AS (
    SELECT 
        EXTRACT(YEAR FROM coverage_effective_dt) AS SALES_YEAR,
        
        -- Individual Product Volumes (Counting valid rows)
        SUM(CASE WHEN coverage_abbreviation_cd IN ('GAP', 'GAPW', 'GAPI') THEN 1 ELSE 0 END) AS GAP_VOLUME,
        SUM(CASE WHEN coverage_abbreviation_cd = 'SCL' THEN 1 ELSE 0 END) AS SCL_VOLUME,
        SUM(CASE WHEN coverage_abbreviation_cd = 'SCA' THEN 1 ELSE 0 END) AS SCA_VOLUME,
        SUM(CASE WHEN coverage_abbreviation_cd = 'IUI' THEN 1 ELSE 0 END) AS IUI_VOLUME,
        -- SUM(CASE WHEN coverage_abbreviation_cd = 'AUT' THEN 1 ELSE 0 END) AS AUT_VOLUME,
        SUM(CASE WHEN coverage_abbreviation_cd = 'HA' THEN 1 ELSE 0 END) AS HA_VOLUME,
        SUM(CASE WHEN coverage_abbreviation_cd = 'ATL' THEN 1 ELSE 0 END) AS ATL_VOLUME,
        SUM(CASE WHEN coverage_abbreviation_cd = 'SSG' THEN 1 ELSE 0 END) AS SSG_VOLUME,
        SUM(CASE WHEN coverage_abbreviation_cd = 'DIP' THEN 1 ELSE 0 END) AS DIP_VOLUME,
        
        -- Total Sold uses the verified 9-product flag (which automatically excludes AUT)
        SUM(NET_CPL_SOLD_FLAG) AS TOTAL_PRODUCTS_SOLD
        
    FROM bdm.temp_ops_product_jy
    WHERE core_capp_filter = 'Core' OR core_capp_filter IS NULL
    GROUP BY 1
)

SELECT 
    COALESCE(l.SALES_YEAR, p.SALES_YEAR) AS SALES_YEAR,
    COALESCE(p.GAP_VOLUME, 0) AS GAP_VOLUME,
    COALESCE(p.SCL_VOLUME, 0) AS SCL_VOLUME,
    COALESCE(p.SCA_VOLUME, 0) AS SCA_VOLUME,
    COALESCE(p.IUI_VOLUME, 0) AS IUI_VOLUME,
    -- COALESCE(p.AUT_VOLUME, 0) AS AUT_VOLUME,
    COALESCE(p.HA_VOLUME, 0) AS HA_VOLUME,
    COALESCE(p.ATL_VOLUME, 0) AS ATL_VOLUME,
    COALESCE(p.SSG_VOLUME, 0) AS SSG_VOLUME,
    COALESCE(p.DIP_VOLUME, 0) AS DIP_VOLUME,
    COALESCE(l.TOTAL_BOOKED_LOANS, 0) AS TOTAL_BOOKED_LOANS,
    COALESCE(p.TOTAL_PRODUCTS_SOLD, 0) AS TOTAL_PRODUCTS_SOLD

FROM loans l
FULL OUTER JOIN products p 
    ON l.SALES_YEAR = p.SALES_YEAR
    
WHERE COALESCE(l.SALES_YEAR, p.SALES_YEAR) BETWEEN 2019 AND 2025
ORDER BY SALES_YEAR ASC;


-- ====================================================================
-- DIAGNOSTIC: LOANS WITH > 8 PRODUCTS
-- Purpose: Isolates anomalous loans and exposes their row-level 
--          product details to identify duplicates or bad data.
-- ====================================================================

WITH Overcounted_Loans AS (
    -- Step 1: Find the specific uai_ids that are breaking the business rule
    SELECT 
        uai_id,
        SUM(NET_CPL_SOLD_FLAG) AS Total_Products_Flagged
    FROM bdm.temp_ops_product_jy
    WHERE EXTRACT(YEAR FROM coverage_effective_dt) = 2025
    GROUP BY uai_id
    HAVING SUM(NET_CPL_SOLD_FLAG) > 8
)

-- Step 2: Pull every product row for those specific loans
SELECT 
    o.Total_Products_Flagged,
    a.uai_id,
    a.coverage_abbreviation_cd AS Product_Code,
    a.coverage_effective_dt AS Sold_Date,
    a.SALE_CT,
    a.NET_CPL_SOLD_FLAG
    
    -- If you are pulling from the raw table directly instead of the temp table, 
    -- you can add columns like Premium Amount or Status here to see why they duplicate.

FROM bdm.temp_ops_product_jy a
INNER JOIN Overcounted_Loans o 
    ON a.uai_id = o.uai_id

-- Sorting so you can read a single loan's history in order
ORDER BY 
    o.Total_Products_Flagged DESC, 
    a.uai_id, 
    a.coverage_abbreviation_cd,
    a.coverage_effective_dt DESC;
    -- ====================================================================
-- RAW PRODUCT DIAGNOSTIC FOR UAI_ID: 1081272927452
