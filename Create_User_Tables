CREATE OR REPLACE TEMP TABLE SB_COMMON.State_Product_Count AS
SELECT 
    State_Cd,
    (CASE WHEN SCL_STATE_AVAIL = 'Y' THEN 1 ELSE 0 END +
     CASE WHEN SCA_STATE_AVAIL = 'Y' THEN 1 ELSE 0 END +
     CASE WHEN IUI_STATE_AVAIL = 'Y' THEN 1 ELSE 0 END +
     CASE WHEN GAP_STATE_AVAIL = 'Y' THEN 1 ELSE 0 END +
     CASE WHEN ATL_STATE_AVAIL = 'Y' THEN 1 ELSE 0 END +
     CASE WHEN DIP_STATE_AVAIL = 'Y' THEN 1 ELSE 0 END +
     CASE WHEN HA_STATE_AVAIL  = 'Y' THEN 1 ELSE 0 END +
     CASE WHEN SSG_STATE_AVAIL = 'Y' THEN 1 ELSE 0 END) AS CPL_Products_Available,
    CASE 
        WHEN (CASE WHEN SCL_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN SCA_STATE_AVAIL='Y' THEN 1 ELSE 0 END + 
              CASE WHEN IUI_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN GAP_STATE_AVAIL='Y' THEN 1 ELSE 0 END + 
              CASE WHEN ATL_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN DIP_STATE_AVAIL='Y' THEN 1 ELSE 0 END + 
              CASE WHEN HA_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN SSG_STATE_AVAIL='Y' THEN 1 ELSE 0 END) <= 5 
            THEN 'Tier A: 4-5 Products'
        WHEN (CASE WHEN SCL_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN SCA_STATE_AVAIL='Y' THEN 1 ELSE 0 END + 
              CASE WHEN IUI_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN GAP_STATE_AVAIL='Y' THEN 1 ELSE 0 END + 
              CASE WHEN ATL_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN DIP_STATE_AVAIL='Y' THEN 1 ELSE 0 END + 
              CASE WHEN HA_STATE_AVAIL='Y' THEN 1 ELSE 0 END + CASE WHEN SSG_STATE_AVAIL='Y' THEN 1 ELSE 0 END) = 6 
            THEN 'Tier B: 6 Products'
        ELSE 'Tier C: 7-8 Products'
    END AS Product_Tier
FROM SB_COMMON.State_Sales_Grid;
